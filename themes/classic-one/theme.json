{
    "name": "Classic One",
    "slug": "classic-one",
    "version": "1.0.0",
    "description": "Classic blog theme with 2010s era look",
    "author": "NebulaCMS",
    "preview": "assets/images/preview.png",
    "requires": {
        "cms_version": "^1.0.0"
    },
    "settings": {
        "colors": {
            "primary": "#0066cc",
            "secondary": "#333333",
            "success": "#5cb85c",
            "info": "#5bc0de",
            "warning": "#f0ad4e",
            "danger": "#d9534f",
            "light": "#f8f9fa",
            "dark": "#333333",
            "background": "#f5f5f5",
            "header": "#333333",
            "footer": "#222222",
            "sidebar": "#ffffff",
            "border": "#dddddd"
        },
        "typography": {
            "primary_font": "Georgia, serif",
            "secondary_font": "Arial, sans-serif",
            "heading_font": "Georgia, serif",
            "body_font": "Arial, sans-serif"
        },
        "layout": {
            "container_width": "1000px",
            "sidebar_position": "right",
            "sidebar_width": "300px"
        }
    },
    "settings_schema": {
        "fields": [
            {
                "key": "colors.primary",
                "type": "color",
                "label": "Primary Color",
                "description": "Main theme color"
            },
            {
                "key": "colors.secondary",
                "type": "color",
                "label": "Secondary Color"
            },
            {
                "key": "colors.success",
                "type": "color",
                "label": "Success Color"
            },
            {
                "key": "colors.info",
                "type": "color",
                "label": "Info Color"
            },
            {
                "key": "colors.warning",
                "type": "color",
                "label": "Warning Color"
            },
            {
                "key": "colors.danger",
                "type": "color",
                "label": "Danger Color"
            },
            {
                "key": "colors.light",
                "type": "color",
                "label": "Light Color"
            },
            {
                "key": "colors.dark",
                "type": "color",
                "label": "Dark Color"
            },
            {
                "key": "colors.background",
                "type": "color",
                "label": "Background Color"
            },
            {
                "key": "colors.header",
                "type": "color",
                "label": "Header Color"
            },
            {
                "key": "colors.footer",
                "type": "color",
                "label": "Footer Color"
            },
            {
                "key": "colors.sidebar",
                "type": "color",
                "label": "Sidebar Color"
            },
            {
                "key": "colors.border",
                "type": "color",
                "label": "Border Color"
            },
            {
                "key": "typography.primary_font",
                "type": "text",
                "label": "Primary Font"
            },
            {
                "key": "typography.secondary_font",
                "type": "text",
                "label": "Secondary Font"
            },
            {
                "key": "typography.heading_font",
                "type": "text",
                "label": "Heading Font"
            },
            {
                "key": "typography.body_font",
                "type": "text",
                "label": "Body Font"
            },
            {
                "key": "layout.container_width",
                "type": "text",
                "label": "Container Width"
            },
            {
                "key": "layout.sidebar_position",
                "type": "text",
                "label": "Sidebar Position",
                "description": "left or right"
            },
            {
                "key": "layout.sidebar_width",
                "type": "text",
                "label": "Sidebar Width"
            }
        ]
    }
}