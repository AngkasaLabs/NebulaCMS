APP_NAME=NebulaCMS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# Scheduled posts: in production, register a system cron that runs `php artisan schedule:run`
# every minute (see README "Production: task scheduler"). Laravel does not run the scheduler by itself.

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nebula_cms
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Media uploads: "public" (local storage/app/public) or "s3" (configure AWS_* below)
MEDIA_DISK=public
# Upload security (see config/upload_security.php)
MEDIA_UPLOAD_MAX_KB=10240
MEDIA_ALLOW_SVG=false
EXTENSION_ZIP_MAX_KB=10240
EXTENSION_ZIP_MAX_ENTRIES=2000
EXTENSION_ZIP_MAX_UNCOMPRESSED_KB=512000
# Optional ClamAV (clamscan must be on PATH or set CLAMAV_BINARY). Toggle only via .env — no admin UI required.
# Verify on server: php artisan upload-scan:status
UPLOAD_SCAN_ENABLED=false
UPLOAD_SCAN_DRIVER=clamav
CLAMAV_BINARY=clamscan
UPLOAD_SCAN_FAIL_ON_ERROR=false
# Generate thumb/medium/large variants for raster images (Intervention Image)
MEDIA_IMAGE_VARIANTS=true
# Optional CDN base for files on the public disk (must match how /storage is exposed)
# MEDIA_URL="${APP_URL}/storage"

QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
# Optional: public URL for objects (e.g. CloudFront). Laravel also uses this for Storage::url on s3 disk.
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
